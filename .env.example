# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/platform

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Request body encryption (32-byte AES-256-GCM key, leave empty to disable)
# Generate: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=

# App
APP_ENV=development
LOG_LEVEL=INFO
